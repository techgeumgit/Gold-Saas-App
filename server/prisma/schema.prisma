// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// TENANT
// ─────────────────────────────────────────
model Tenant {
  id          String    @id @default(uuid())
  name        String                          // "Acme Jewels"
  slug        String    @unique               // "acme-jewels" → subdomain routing
  plan        Plan      @default(TRIAL)
  trialEndsAt DateTime?
  isActive    Boolean   @default(true)
  currency    String    @default("INR")       // tenant's default operating currency
  timezone    String    @default("Asia/Kolkata")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users         User[]
  roles         Role[]
  refreshTokens RefreshToken[]
}

enum Plan {
  TRIAL
  STANDARD
  ENTERPRISE
}

// ─────────────────────────────────────────
// ROLE  (per-tenant, dynamic)
// ─────────────────────────────────────────
model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String                          // "Owner", "Cashier", "Auditor"
  permissions Json                            // { canSell: true, canEditInventory: false ... }
  isDefault   Boolean  @default(false)        // seeded automatically for new tenants
  isSystem    Boolean  @default(false)        // true = cannot be deleted (OWNER role)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  users  User[]

  @@unique([name, tenantId])                  // "Manager" is unique per tenant
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────
model User {
  id           String    @id @default(uuid())
  tenantId     String
  roleId       String
  name         String
  email        String
  phone        String?
  passwordHash String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  role          Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]

  @@unique([email, tenantId])                 // same email allowed across different tenants
}

// ─────────────────────────────────────────
// REFRESH TOKEN  (one row per active session)
// ─────────────────────────────────────────
model RefreshToken {
  id         String   @id @default(uuid())
  tenantId   String                           // for fast tenant-level session wipe
  userId     String
  token      String   @unique                 // SHA-256 hashed before storing
  deviceInfo String?                          // "Chrome on MacOS", "iPhone Safari"
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}
